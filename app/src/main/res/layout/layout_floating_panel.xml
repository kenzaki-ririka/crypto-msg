<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_panel"
    android:padding="20dp"
    android:elevation="16dp">

    <!-- 顶部栏：标题 + 关闭按钮 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="12dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="🔒 加密聊天"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold" />

        <ImageButton
            android:id="@+id/btn_close"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="@android:color/transparent"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:contentDescription="关闭"
            android:tint="#AAAAAA" />
    </LinearLayout>

    <!-- 联系人选择器 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="12dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="联系人: "
            android:textColor="#CCCCCC"
            android:textSize="14sp" />

        <Spinner
            android:id="@+id/spinner_contact"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:background="@drawable/bg_spinner"
            android:popupBackground="#2A2A3E"
            android:paddingStart="12dp"
            android:paddingEnd="12dp" />
    </LinearLayout>

    <!-- 输入框 -->
    <EditText
        android:id="@+id/et_input"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="80dp"
        android:background="@drawable/bg_input"
        android:hint="输入明文或粘贴密文..."
        android:textColor="#FFFFFF"
        android:textColorHint="#666680"
        android:textSize="14sp"
        android:padding="14dp"
        android:gravity="top|start"
        android:inputType="textMultiLine"
        android:layout_marginBottom="12dp" />

    <!-- 操作按钮行 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="12dp">

        <Button
            android:id="@+id/btn_encrypt"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:text="🔐 加密发送"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:background="@drawable/bg_button_encrypt"
            android:layout_marginEnd="6dp" />

        <Button
            android:id="@+id/btn_decrypt"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:text="🔓 解密"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:background="@drawable/bg_button_decrypt"
            android:layout_marginStart="6dp" />
    </LinearLayout>

    <!-- 结果显示区 -->
    <TextView
        android:id="@+id/tv_result"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="48dp"
        android:background="@drawable/bg_result"
        android:textColor="#E0E0FF"
        android:textSize="13sp"
        android:padding="14dp"
        android:gravity="top|start"
        android:textIsSelectable="true"
        android:hint="结果将显示在这里"
        android:textColorHint="#555570"
        android:layout_marginBottom="10dp" />

    <!-- 底部按钮行 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end">

        <Button
            android:id="@+id/btn_copy"
            android:layout_width="wrap_content"
            android:layout_height="38dp"
            android:text="📋 复制"
            android:textColor="#CCCCDD"
            android:textSize="13sp"
            android:background="@drawable/bg_button_secondary"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:layout_marginEnd="8dp" />

        <Button
            android:id="@+id/btn_autofill"
            android:layout_width="wrap_content"
            android:layout_height="38dp"
            android:text="✏️ 填入输入框"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:background="@drawable/bg_button_autofill"
            android:paddingStart="16dp"
            android:paddingEnd="16dp" />
    </LinearLayout>

</LinearLayout>
